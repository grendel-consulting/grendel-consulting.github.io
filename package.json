{
  "name": "grendel-consulting.github.io",
  "description": "Documentation handbook entry point for Grendel Consulting",
  "author": {
    "name": "James Ramirez"
  },
  "version": "0.2.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "preinstall": "only-allow pnpm",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "format": "prettier --ignore-path .gitignore --write \"**/*.{js,mjs,json,ts,tsx,md,mdx,yml,astro,feature}\"",
    "browsers": "turbo run browsers",
    "e2e": "turbo run e2e"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead"
    ],
    "development": [
      "last 2 Chrome versions",
      "last 1 Firefox versions",
      "last 1 Safari versions"
    ]
  },
  "devDependencies": {
    "only-allow": "1.2.2",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-gherkin": "3.1.3",
    "turbo": "2.9.1",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ],
    "overrides": {
      "sharp@<0.32.6": ">=0.32.6",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "mdast-util-to-hast@>=13.0.0 <13.2.1": ">=13.2.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0",
      "svgo@=4.0.0": ">=4.0.1"
    }
  }
}
